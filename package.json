{
    "name": "drizzle",
    "version": "1.0.0",
    "packageManager": "bun@1.2.22",
    "main": "index.js",
    "scripts": {
        "start": "node dist/server.js",
        "dev": "APP_ENV=staging bun --preload ./src/bootstrap/env-preload.ts --hot ./src/server.ts",
        "build": "tsc",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "lint": "eslint \"src/**/*.ts\"",
        "predeploy": "bun run format && bun run lint && bun run typecheck",
        "test:e2e": "bun run db:seed:test && APP_ENV=testing bun test --preload ./test/setup/preload.ts test/scenarios/",
        "dev:test": "APP_ENV=testing bun --preload ./src/bootstrap/env-preload.ts --hot ./src/server.ts",
        "db:bootstrap:test": "APP_ENV=testing bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/bootstrap-test-db.ts",
        "db:seed:test": "APP_ENV=testing bun --preload ./src/bootstrap/env-preload.ts ./src/db/seed-test.ts",
        "db:seed": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/seed-safe.ts",
        "db:seed:pr": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/seed-pr.ts",
        "db:seed:demo:pr": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/seed-demo-pr.ts",
        "db:rebuild": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/rebuild-schema.ts",
        "db:reset": "bun run db:rebuild && bun run db:seed",
        "db:reset:pr": "bun run db:rebuild && bun run db:seed:pr",
        "db:platform:create": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/platform-create.ts",
        "db:platform:bootstrap": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/platform-bootstrap.ts",
        "db:access:audit": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/audit-admin-access.ts",
        "db:redbull:ensure-teams": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/ensure-redbull-alignment-teams.ts",
        "db:redbull:export-snapshot": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/export-redbull-alignment-snapshot.ts",
        "db:redbull:apply-alignment": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/apply-redbull-alignment-results.ts",
        "db:access:cleanup-stale-default-overrides": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/cleanup-stale-default-overrides.ts",
        "db:access:cleanup-stale-default-overrides:apply": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/cleanup-stale-default-overrides.ts --apply",
        "db:access:sync-defaults": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/sync-default-access-policies.ts",
        "db:access:sync-defaults:apply": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/sync-default-access-policies.ts --apply",
        "dbops:login-report:prod": "bash scripts/dbops/login-report.sh prod",
        "dbops:login-report:staging": "bash scripts/dbops/login-report.sh staging",
        "dbops:fingerprint:prod": "bash scripts/dbops/fingerprint-db.sh prod",
        "dbops:fingerprint:staging": "bash scripts/dbops/fingerprint-db.sh staging",
        "dbops:refresh-staging:dry": "APP_ENV=staging bash scripts/dbops/refresh-staging-full.sh dry-run",
        "dbops:refresh-staging": "APP_ENV=staging bash scripts/dbops/refresh-staging-full.sh apply",
        "dbops:refresh-staging:bare:dry": "APP_ENV=staging bash scripts/dbops/refresh-staging-from-prod.sh dry-run",
        "dbops:refresh-staging:bare": "APP_ENV=staging bash scripts/dbops/refresh-staging-from-prod.sh apply",
        "deploy:status": "bash scripts/deploy/check-all.sh",
        "deploy:status:api": "bash scripts/deploy/check-codepipeline.sh && bash scripts/deploy/check-eb.sh",
        "deploy:status:amplify": "bash scripts/deploy/check-amplify.sh",
        "deploy:trigger:amplify": "bash scripts/deploy/trigger-amplify.sh",
        "export:asset-catalog": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/export-asset-catalog.ts",
        "asset-family:backfill:report": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/generate-asset-family-backfill.ts",
        "asset-family:backfill:apply": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/apply-asset-family-backfill.ts",
        "asset-family:backfill:validate": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/validate-asset-family-backfill.ts",
        "bookings:backfill:dry": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/backfill-pre-confirmed-bookings.ts --dry-run",
        "bookings:backfill:apply": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/backfill-pre-confirmed-bookings.ts",
        "stock-movements:backfill:dry": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/backfill-outbound-ad-hoc-movements.ts --dry-run",
        "stock-movements:backfill:apply": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/backfill-outbound-ad-hoc-movements.ts",
        "import:pr-assets": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/seed-pr-assets.ts",
        "import:pr-assets:dry": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/seed-pr-assets.ts --dry-run",
        "import:pr-assets:no-photos": "bun --preload ./src/bootstrap/env-preload.ts ./src/db/scripts/seed-pr-assets.ts --skip-photos"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@aws-sdk/client-s3": "^3.958.0",
        "@aws-sdk/s3-request-presigner": "^3.958.0",
        "@pulumi/aws": "^7.16.0",
        "@pulumi/pulumi": "^3.216.0",
        "bcrypt": "^6.0.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dayjs": "^1.11.19",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.45.1",
        "exceljs": "^4.4.0",
        "express": "^5.2.1",
        "http-status": "^2.1.0",
        "jsonwebtoken": "^9.0.3",
        "ms": "^2.1.3",
        "multer": "^2.0.2",
        "node-cron": "^4.2.1",
        "nodemailer": "^7.0.12",
        "papaparse": "^5.5.3",
        "pdfkit": "^0.17.2",
        "pg": "^8.16.3",
        "qrcode": "^1.5.4",
        "resend": "^6.9.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.2.1"
    },
    "devDependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-serve-static-core": "^5.1.1",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/ms": "^2.1.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^25.0.2",
        "@types/node-cron": "^3.0.11",
        "@types/nodemailer": "^7.0.4",
        "@types/papaparse": "^5.5.2",
        "@types/pdfkit": "^0.17.4",
        "@types/pg": "^8.16.0",
        "@types/qrcode": "^1.5.6",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@typescript-eslint/eslint-plugin": "^8.53.1",
        "@typescript-eslint/parser": "^8.53.1",
        "drizzle-kit": "^0.31.8",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.1.0",
        "prettier": "^3.7.4",
        "ts-node-dev": "^2.0.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "bun": ">=1.2.0",
        "node": ">=20"
    }
}
