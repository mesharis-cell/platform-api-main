# Security scan reports
reports/

# Plaintext credential dumps from src/db/scripts/seed-users.ts
seeded-users-*.txt

# seed-users.ts stays local-only — it accumulates real user lists
# (names + emails) in its USERS block. Keeping it out of git avoids
# shipping client PII into history. Copy from a teammate if you need it.
src/db/scripts/seed-users.ts

# One-off prod data-fix scripts — scoped to specific entity IDs, not
# reusable, shouldn't live in git history. Name pattern: fix-*.ts
src/db/scripts/fix-*.ts

# Local backups written by fix-* scripts before destructive operations.
# Keep these out of git — they can contain prod data and accumulate.
backups/
