# E2E test environment — copy to .env.test and fill in.
# See api/docs/e2e-testing-system.md and api/test/README.md.

# Dedicated testing PostgreSQL. MUST be a different database from staging + prod.
DATABASE_URL_TEST=postgresql://user:pass@host:5432/kadence_test

# Dedicated Resend API key for test runs. Separate from staging/prod keys so
# test email metadata does not pollute production Resend logs. Reuse the same
# verified sending domain as staging/prod.
RESEND_API_KEY_TEST=re_test_xxxxxxxxxxxxxxxxxx

# REQUIRED for `bun run db:bootstrap:test` — the existing destructive-guard
# refuses to run against a database whose Supabase project ref (or host) is
# not explicitly allowlisted. Set this to the project ref of YOUR TEST DB
# before running bootstrap. Comma-separated for multiple.
DB_DESTRUCTIVE_ALLOWED_SUPABASE_REFS=your-test-project-ref-here
# For non-Supabase hosts, use DB_DESTRUCTIVE_ALLOWED_HOSTS instead (same CSV format).
# DB_DESTRUCTIVE_ALLOWED_HOSTS=your-test-host-here

# Optional — set this to the exact confirmation phrase to skip the interactive
# TTY prompt during bootstrap. Format: "SEED <project-ref>" (the bootstrap
# script prints the expected phrase if it fails).
# DB_DESTRUCTIVE_CONFIRM=SEED your-test-project-ref-here

# Optional — forces the test API to bind to a specific port instead of random.
# TEST_API_PORT=

# The following are auto-set by test/setup/preload.ts based on the values
# above and do not need to be set manually:
#   APP_ENV=testing
#   DATABASE_URL=<DATABASE_URL_TEST>
#   RESEND_API_KEY=<RESEND_API_KEY_TEST>
